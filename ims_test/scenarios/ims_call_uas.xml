<?xml version="1.0" encoding="ISO-8859-1" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<scenario name="IMS Call UAS with Registration">
  <!-- 定义全局变量 -->
  <Global variables="tmp_expires,refresh_time"/>

  <!-- 主注册流程 -->
  <label id="register"/>

  <!-- 发送REGISTER请求 -->
  <send retrans="500">
    <![CDATA[
      REGISTER sip:[field1] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
      Route: <sip:[field1];lr>
      From: <sip:[field0]@[field1]>;tag=[call_number]
      To: <sip:[field0]@[field1]>
      Call-ID: [call_id]
      CSeq: [cseq] REGISTER
      Max-Forwards: 70
      Contact: <sip:[field0]@[local_ip]:[local_port]>
      User-Agent: SIPp IMS Client
      Expires: 1800
      Content-Length: 0
    ]]>
  </send>

  <!-- 可选：接收100 Trying -->
  <recv response="100" optional="true">
  </recv>

  <!-- 接收200 OK并获取expires值 -->
  <recv response="200" timeout="5000" next="subscribe_label" test="need_subscribe">
    <action>
      <!-- 计算刷新时间 -->
      <ereg regexp=".*expires=([0-9]+).*" search_in="hdr" header="Contact:" check_it="true" assign_to="tmp_expires" default_value="3600"/>
      <ereg regexp="([0-9]+)" search_in="hdr" header="Expires:" check_it="true" assign_to="tmp_expires" default_value="[$tmp_expires]"/>
      <todouble assign_to="tmp_expires" variable="tmp_expires"/>
      <divide assign_to="tmp_expires" value="2"/>
      <todouble assign_to="refresh_time" variable="tmp_expires"/>
      <multiply assign_to="refresh_time" value="1000"/>
      
      <!-- 从收到的CSeq头中提取实际值 -->
      <ereg regexp="([0-9]+)" search_in="hdr" header="CSeq:" check_it="true" assign_to="cseq_value"/>
      <todouble assign_to="cseq_value" variable="cseq_value"/>
      <test assign_to="need_subscribe" variable="cseq_value" compare="less_than" value="2"/>
    </action>
  </recv>

  <!-- 单轮：注册完成后等待来电，不再循环刷新 -->
  <pause milliseconds="3600000" />

  <label id="subscribe_label"/>
  <!-- 单轮：注册完成后等待来电，不再循环刷新 -->
  <pause milliseconds="3600000" />

  <!-- 定义响应时间分布表（单位：毫秒） -->
  <ResponseTimeRepartition value="10, 20, 30, 40, 50, 100, 150, 200"/>

  <!-- 定义呼叫时长分布表（单位：毫秒） -->
  <CallLengthRepartition value="10, 50, 100, 500, 1000, 5000, 10000, 20000, 30000"/>

</scenario> 