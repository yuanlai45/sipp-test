<?xml version="1.0" encoding="ISO-8859-1" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<scenario name="Basic Register">
  <!-- 定义全局变量 -->
  <Global variables="tmp_expires,refresh_time,first_regsiter"/>

  <!-- 主注册流程 -->
  <label id="register"/>
  
  <!-- 发送REGISTER请求 -->
  <send retrans="3000">
    <![CDATA[
      REGISTER sip:[field1] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
      Route: <sip:[field1];lr>
      From: <sip:[field0]@[field1]>;tag=[call_number]
      To: <sip:[field0]@[field1]>
      Call-ID: [call_id]
      CSeq: [cseq] REGISTER
      Max-Forwards: 70
      P-Visited-Network-ID: ims.mnc011.mcc460.3gppnetwork.org
      Contact: <sip:[field0]@[local_ip]:[local_port]>
      User-Agent: SIPp IMS Client
      Expires: [reg_period]
      Content-Length: 0
    ]]>
  </send>

  <!-- 可选：接收100 Trying -->
  <recv response="100" optional="true">
  </recv>

  <!-- 接收200 OK并获取expires值 -->
  <recv response="200">
    <action>
      <!-- 尝试从Contact头中获取expires参数（单位：秒） -->
      <ereg regexp=".*expires=([0-9]+).*" search_in="hdr" header="Contact:" check_it="true" assign_to="tmp_expires" default_value="3600"/>
      <!-- 如果Contact头中没有expires，则尝试从Expires头获取（单位：秒） -->
      <ereg regexp="([0-9]+)" search_in="hdr" header="Expires:" check_it="true" assign_to="tmp_expires" default_value="[$tmp_expires]"/>
      <!-- 将expires值转换为数值 -->
      <todouble assign_to="tmp_expires" variable="tmp_expires"/>
      <!-- 计算刷新时间（毫秒） -->
      <divide assign_to="tmp_expires" value="2"/>
      <todouble assign_to="refresh_time" variable="tmp_expires"/>
      <multiply assign_to="refresh_time" value="1000"/>
    </action>
  </recv>

  <!-- 发送SUBSCRIBE请求 -->
  <!--
  <send retrans="500" condexec="first_regsiter" condexec_inverse="true">
    <![CDATA[
      SUBSCRIBE sip:[field0]@[field1] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch];rport
      Route: <sip:[remote_ip]:[remote_port];lr>
      From: <sip:[field0]@[field1]>;tag=[call_number]
      To: <sip:[field0]@[field1]>
      Call-ID: [call_id]
      CSeq: 1 SUBSCRIBE
      Contact: <sip:[field0]@[local_ip]:[local_port];transport=TCP>;+sip.instance="<urn:gsma:imei:86253004-794212-0>"
      Require: sec-agree
      Proxy-Require: sec-agree
      Supported: path,sec-agree
      Event: reg
      Accept: application/reginfo+xml
      P-Access-Network-Info: 3GPP-E-UTRAN-FDD;utran-cell-id-3gpp=4600100015EE0000
      Max-Forwards: 70
      User-Agent: IM-client/OMA1.0 HW-Rto/V1.0
      Expires: [reg_period]
      Content-Length: 0
    ]]>
  </send>
  <recv response="200" condexec="first_regsiter" condexec_inverse="true">
  </recv>
  -->
  <!-- 设置first_regsiter为false -->
  <nop>
    <action>
      <assignstr assign_to="first_regsiter" value="false"/>
    </action>
  </nop>


  <!-- 等待到expires的一半时间后进行刷新 -->
  <pause variable="refresh_time"/>
  
  <!-- 返回主注册流程进行刷新 -->
  <nop next="register"/>

  <!-- 全局OPTIONS处理分支 -->
  <label id="options_branch"/>
  <recv request="OPTIONS" optional_global="1" next="options_response">
  </recv>

  <label id="options_response"/>
  <send next="options_branch">
    <![CDATA[
      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:[field0]@[local_ip]:[local_port]>
      Allow: INVITE, ACK, CANCEL, OPTIONS, BYE, REFER, SUBSCRIBE, NOTIFY, PUBLISH, MESSAGE, INFO
      Content-Length: 0
    ]]>
  </send>

  <!-- 定义响应时间分布表（单位：毫秒） -->
  <ResponseTimeRepartition value="10, 20, 30, 40, 50, 100, 150, 200"/>

  <!-- 定义呼叫时长分布表（单位：毫秒） -->
  <CallLengthRepartition value="10, 50, 100, 500, 1000, 5000, 10000"/>

</scenario>